# 系统环境变量配置
# 复制此文件为 .env 并填入你的 API Key

# 向量数据库目录
VECTOR_DB_PATH=./vector_db

# 集合名称
COLLECTION_NAME=taoguba_posts

# 默认 LLM 提供商（可选：zhipu / deepseek / openai / qwen / minimax / kimi）
DEFAULT_LLM_PROVIDER=qwen

# 通义千问 API Key
QWEN_API_KEY=
# 可选：指定模型（默认为 qwen-plus）
# QWEN_MODEL=qwen-plus

# 智谱 AI API Key
ZHIPU_API_KEY=
# 可选：指定模型（默认为 glm-4.5-air）
# ZHIPU_MODEL=glm-4.5-air

# DeepSeek API Key
DEEPSEEK_API_KEY=
# 可选：指定模型（默认为 deepseek-chat）
# DEEPSEEK_MODEL=deepseek-chat

# OpenAI API Key
OPENAI_API_KEY=
# 可选：指定模型（默认为 gpt-4o-mini）
# OPENAI_MODEL=gpt-4o-mini

# MiniMax API Key
MINIMAX_API_KEY=
# 可选：指定模型（默认为 MiniMax-M2.7）
# MINIMAX_MODEL=MiniMax-M2.7

# Kimi (Moonshot) API Key
KIMI_API_KEY=
# 可选：指定模型（默认为 kimi-k2.5）
# KIMI_MODEL=kimi-k2.5
